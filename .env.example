# ================================================
# NEXUS CLOUD — Environment Configuration
# ================================================
# Copy this file to .env and fill in your values

# Pakasir Payment Gateway
VITE_PAKASIR_PROJECT_ID=your_project_slug
VITE_PAKASIR_API_KEY=your_api_key

# Pterodactyl Panel
VITE_PTERODACTYL_DOMAIN=https://your-panel.domain.com
VITE_PTERODACTYL_API_KEY=your_ptero_application_api_key

# Telegram Bot (for reference)
VITE_TELEGRAM_BOT_TOKEN=your_bot_token
